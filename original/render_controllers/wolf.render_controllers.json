{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.wolf": {
      "arrays": {
        "textures": {
          "Array.default": [
            "Texture.pale_default",
            "Texture.ashen_default",
            "Texture.black_default",
            "Texture.chestnut_default",
            "Texture.rusty_default",
            "Texture.snowy_default",
            "Texture.spotted_default",
            "Texture.striped_default",
            "Texture.woods_default",
            "Texture.mars_default"
          ],
          "Array.angry": [
            "Texture.pale_angry",
            "Texture.ashen_angry",
            "Texture.black_angry",
            "Texture.chestnut_angry",
            "Texture.rusty_angry",
            "Texture.snowy_angry",
            "Texture.spotted_angry",
            "Texture.striped_angry",
            "Texture.woods_angry",
            "Texture.mars_angry"
          ],
          "Array.tame": [
            "Texture.pale_tame",
            "Texture.ashen_tame",
            "Texture.black_tame",
            "Texture.chestnut_tame",
            "Texture.rusty_tame",
            "Texture.snowy_tame",
            "Texture.spotted_tame",
            "Texture.striped_tame",
            "Texture.woods_tame",
            "Texture.mars_tame"
          ]
        }
      },
      "geometry": "query.is_baby ? geometry.baby : (Geometry.default)",
      "materials": [
        {
          "*": "Material.default"
        }
      ],
      "textures": [
        "query.is_name_any('mars', 'Mars', 'MARS') && query.has_owner ? Texture.mars_tame : (query.is_name_any('blocco', 'Blocco', 'BLOCCO') && query.has_owner ? Texture.blocco_tame : (query.is_name_any('skeleton', 'bones', 'esqueleto', 'Skeleton', 'Bones', 'Esqueleto' ) && query.has_owner ? Texture.skeleton_tame :query.is_name_any('Dennis', 'DENNIS', 'dennis') && query.has_owner ? Texture.dennis_tame : ((query.is_angry ? Array.angry[query.variant] : (query.is_tamed ? Array.tame[query.variant] : Array.default[query.variant])))))"
      ]
    }
  }
}