{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.chicken.v2": {
      "arrays": {
        "textures": {
          "Array.textures": [
            "Texture.default",
            "Texture.warm",
            "Texture.cold"
          ]
        },
        "geometries": {
          "Array.geos": [
            "Geometry.default",
            "Geometry.warm",
            "Geometry.cold",
            "Geometry.chick"
          ]
        }
      },
      "geometry": "query.is_baby ? geometry.chick : Array.geos[v.index]",
      "materials": [
        {
          "*": "v.is_cold ? Material.cold : Material.default"
        },
        {
          "leg*": "Material.legs"
        }
      ],
      "textures": [ "Array.textures[v.index]" ]
    }
  }
}