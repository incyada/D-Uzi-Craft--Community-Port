{
  "format_version": "1.10.0",
  "render_controllers": {
    "controller.render.happy_ghast": {
      "geometry": "query.is_name_any('baby', 'BABY', 'Baby') && query.is_baby ? Geometry.baby : Geometry.default",
      "materials": [
        {
          "*": "query.is_name_any('baby', 'BABY', 'Baby') && query.is_baby ? Material.baby : Material.default"
        }
      ],
      "textures": [
        "query.is_name_any('baby', 'BABY', 'Baby') && query.is_baby ? Texture.baby : (query.is_baby ? Texture.ghastling : Texture.happy_ghast)"
      ]
    },
    "controller.render.happy_ghast_ropes": {
      "geometry": "Geometry.ropes",
      "materials": [
        {
          "*": "Material.default"
        }
      ],
      "textures": [
        "Texture.ropes"
      ],
      "part_visibility": [
        {
          "*": "variable.render_ropes"
        }
      ]
    }
  }
}