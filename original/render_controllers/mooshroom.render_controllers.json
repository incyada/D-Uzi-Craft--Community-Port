{
  "format_version": "1.10.0",
  "render_controllers": {
    "controller.render.mooshroom": {
      "arrays": {
        "textures": {
          "Array.skins": [
            "Texture.default",
            "Texture.brown"
          ]
        }
      },
      "geometry": "query.is_baby ? geometry.baby : (Geometry.default)",
      "materials": [
        {
          "*": "Material.default"
        }
      ],
      "textures": [
        "Array.skins[query.variant]"
      ]
    }
  }
}