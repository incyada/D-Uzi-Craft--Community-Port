{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.cow.v2": {
      "arrays": {
        "textures": {
          "Array.textures": [
            "Texture.default",
            "Texture.warm",
            "Texture.cold"
          ]
        },
        "geometries": {
          "Array.geos": [
            "Geometry.default",
            "Geometry.warm",
            "Geometry.cold"
          ]
        }
      },
      "geometry": "query.is_baby ? geometry.cow_baby : Array.geos[v.index]",
      "materials": [ { "*": "v.is_cold ? Material.cold : Material.default" } ],
      "textures": [ "query.get_name == 'Moon' ? Texture.Moon : (query.get_name == 'PinkMoo' ? Texture.Pink_Moobloom : (query.get_name == 'Moobloom' ? Texture.Moobloom :(query.get_name == 'Moolip' ? Texture.Moolip : (Array.textures[v.index]))))" ]
    }
  }
}
