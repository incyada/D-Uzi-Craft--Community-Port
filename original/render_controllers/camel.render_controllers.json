{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.camel": {
      "geometry": "query.is_baby ? geometry.default_b : Geometry.default",
      "materials": [
        {
          "*": "Material.default"
        }
      ],
      "textures": [
        "query.is_baby ? Texture.default_b : Texture.default"
      ],
      "part_visibility": [
        {
          "saddle": "query.is_saddled"
        },
        {
          "bridle": "query.is_saddled"
        },
        {
          "reins*": "query.is_saddled && query.has_rider"
        }
      ]
    }
  }
}