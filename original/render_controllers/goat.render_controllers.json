{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.goat": {
      "geometry": "query.is_baby ? geometry.default_b : Geometry.default",
      "part_visibility": [
        {
          "right_horn": "variable.goat_has_right_horn"
        },
        {
          "left_horn": "variable.goat_has_left_horn"
        }
      ],
      "materials": [
        {
          "*": "Material.default"
        }
      ],
      "textures": [
        "Array.Xskins[variable.Xvar]"
      ],
      "arrays": {
        "textures": {
          "Array.Xskins": [
            "Texture.default",
            "Texture.default2"
          ]
        }
      }
    }
  }
}