{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.snowgolem": {
      "arrays": {
        "textures": {
          "Array.skins": [
            "Texture.default"
          ],
          "Array.Xskins": [
            "Texture.default",
            "Texture.default2",
            "Texture.default3",
            "Texture.default4",
            "Texture.default5"
          ]
        }
      },
      "geometry": "Geometry.default",
      "materials": [
        {
          "*": "Material.default"
        },
        {
          "head*": "Material.head"
        }
      ],
      "textures": [
        "query.get_name == 'Melon' ? Texture.melon : (Array.Xskins[variable.Xvar])"
      ]
    }
  }
}